FROM --platform=linux/amd64 rust:latest

RUN cargo install cargo-watch

WORKDIR /app

# Copy manifests first to cache dependencies
COPY whiteboarder/Cargo.toml whiteboarder/Cargo.lock ./whiteboarder/
RUN cd whiteboarder && mkdir src && echo "fn main() {}" > src/main.rs && cargo build && rm src/*.rs

# Copy the full source
COPY whiteboarder/src ./whiteboarder/src
COPY whiteboarder/assets ./whiteboarder/assets

RUN cd whiteboarder && touch src/main.rs

EXPOSE 3000

# Rebuild and restart on file changes
CMD ["cargo", "watch", "--poll", "--workdir", "whiteboarder", "-x", "run"]
